# =============================
# Server
# =============================
PORT=3001
NODE_ENV=development

# =============================
# SQL Server
# =============================
DB_SERVER=localhost
DB_DATABASE=PharmacyFinance
DB_USER=sa
DB_PASSWORD=YourPassword123
